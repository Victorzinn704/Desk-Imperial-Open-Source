{
  "name": "partner-portal-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Base arquitetural do portal empresarial com foco em UX/UI, seguranca e observabilidade.",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:studio": "npm --workspace @partner/api exec prisma studio --schema prisma/schema.prisma",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "seed": "npm --workspace @partner/api run prisma:seed",
    "gulp:images": "gulp images",
    "gulp:clean": "gulp clean",
    "gulp:watch": "gulp watch",
    "refactor:desk-styles": "node scripts/refactor-desk-tailwind.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "del": "^8.0.1",
    "globals": "^16.4.0",
    "gulp": "^5.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
