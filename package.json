{
  "name": "desk-imperial",
  "private": true,
  "version": "0.1.0",
  "description": "Sistema gratuito de gestão comercial para pequenos e médios comerciantes brasileiros.",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose --env-file .env -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose --env-file .env -f infra/docker/docker-compose.yml down",
    "obs:up": "docker compose -f infra/docker/docker-compose.observability.yml up -d",
    "obs:down": "docker compose -f infra/docker/docker-compose.observability.yml down",
    "db:studio": "npm --workspace @partner/api exec prisma studio --schema prisma/schema.prisma",
    "local:backend:prepare": "npm run db:up && node ./scripts/wait-for-local-infra.mjs && node ./scripts/prisma-generate-local.mjs && npm --workspace @partner/api run prisma:migrate:deploy && npm run seed && npm --workspace @partner/api run prisma:repair-demo",
    "local:backend:sync-demo": "npm run seed && npm --workspace @partner/api run prisma:repair-demo",
    "smoke:local:bootstrap": "node ./scripts/local-bootstrap-smoke.mjs",
    "smoke:operations:performance": "node ./scripts/operations-performance-smoke.mjs",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ./scripts/run-with-sanitized-node-options.mjs turbo run test",
    "test:critical": "npm --workspace @partner/api run test:critical && npm --workspace @partner/web run test:critical",
    "test:coverage": "npm --workspace @partner/api run test -- --coverage && npm --workspace @partner/web run test:coverage",
    "test:e2e:critical": "npm --workspace @partner/web run test:e2e:critical",
    "test:load:critical": "k6 run tests/load/k6/critical-flows.js",
    "test:load:ci": "k6 run tests/load/k6/ci-latency-gate.js",
    "repo:scan-public": "node ./scripts/scan-public-repo-risks.mjs",
    "repo:drift": "node ./scripts/git-drift-report.mjs",
    "security:audit-runtime": "node ./scripts/check-runtime-audit-allowlist.mjs",
    "quality:scope": "node ./scripts/check-worktree-scope.mjs",
    "quality:scope:strict": "node ./scripts/check-worktree-scope.mjs --strict",
    "quality:contracts": "node ./scripts/check-public-contracts.mjs",
    "quality:warnings": "node ./scripts/quality-warning-map.mjs",
    "quality:warnings:strict": "node ./scripts/quality-warning-map.mjs --fail-on-alert",
    "quality:preflight": "node ./scripts/quality-preflight.mjs",
    "quality:preflight:full": "node ./scripts/quality-preflight.mjs --full",
    "verify:owner-pwa": "npm --workspace @partner/web run test -- components/owner-mobile/owner-mobile-shell.test.tsx components/owner-mobile/owner-today-view.test.tsx components/owner-mobile/owner-comandas-view.test.tsx components/owner-mobile/owner-finance-view.test.tsx components/owner-mobile/owner-account-view.test.tsx components/owner-mobile/owner-mobile-pdv-tab.test.tsx components/owner-mobile/owner-quick-register-view.test.tsx components/staff-mobile/mobile-order-builder.test.tsx",
    "verify:current-phase": "npm run quality:scope && npm run quality:contracts && npm run test:critical && npm run verify:owner-pwa && npm run typecheck && npm --workspace @partner/api run build:verify && npm --workspace @partner/web run build",
    "verify:current-phase:strict": "npm run quality:preflight && npm run verify:current-phase",
    "typecheck": "turbo run typecheck",
    "openapi:generate": "npm --workspace @partner/api run openapi:generate",
    "openapi:check": "npm run openapi:generate && git diff --exit-code -- packages/api-contract/openapi.json",
    "lint-staged": "lint-staged",
    "seed": "npm --workspace @partner/api run prisma:seed",
    "gulp:images": "gulp images",
    "gulp:clean": "gulp clean",
    "gulp:watch": "gulp watch",
    "refactor:desk-styles": "node scripts/refactor-desk-tailwind.mjs",
    "sonar:regression:check": "node ./scripts/check-sonar-regression.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node ./scripts/patch-next-postcss.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,mts,cts,js,mjs,cjs}": [
      "prettier --write",
      "eslint --no-config-lookup --config apps/web/eslint.config.mjs --fix --max-warnings 0"
    ],
    "apps/api/**/*.{ts,tsx,mts,cts,js,mjs,cjs}": [
      "prettier --write",
      "eslint --no-config-lookup --config apps/api/eslint.config.mjs --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "cross-env": "^10.1.0",
    "del": "^8.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "gulp": "^5.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  },
  "dependencies": {
    "apexcharts": "^5.10.5",
    "next-themes": "^0.4.6",
    "react-apexcharts": "^2.1.0"
  },
  "overrides": {
    "next": {
      ".": "$next",
      "postcss": "8.5.10"
    },
    "postcss": "8.5.10",
    "protobufjs": "7.5.5",
    "vite": "8.0.10"
  }
}
