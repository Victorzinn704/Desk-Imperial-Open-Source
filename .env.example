# Shared
NODE_ENV=development
APP_NAME=partner-portal

# Web
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partner_portal
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/partner_portal
TRUST_PROXY=false
COOKIE_SECRET=change-me
CSRF_SECRET=change-me
ENCRYPTION_KEY=change-me
SESSION_TTL_HOURS=24
DEMO_ACCOUNT_EMAIL=demo@partnerportal.com
DEMO_DAILY_LIMIT_MINUTES=20
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_MINUTES=15
CONSENT_VERSION=2026.03
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=3
PASSWORD_RESET_WINDOW_MINUTES=15
PASSWORD_RESET_LOCK_MINUTES=30
PASSWORD_RESET_CODE_MAX_ATTEMPTS=5
PASSWORD_RESET_CODE_WINDOW_MINUTES=15
PASSWORD_RESET_CODE_LOCK_MINUTES=30
EMAIL_VERIFICATION_MAX_ATTEMPTS=3
EMAIL_VERIFICATION_WINDOW_MINUTES=15
EMAIL_VERIFICATION_LOCK_MINUTES=30
EMAIL_VERIFICATION_CODE_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_CODE_WINDOW_MINUTES=15
EMAIL_VERIFICATION_CODE_LOCK_MINUTES=30
EXCHANGE_RATES_URL=https://economia.awesomeapi.com.br/last/USD-BRL,EUR-BRL,BRL-USD,BRL-EUR,USD-EUR,EUR-USD
EXCHANGE_RATES_CACHE_SECONDS=300
GEOCODING_URL=https://nominatim.openstreetmap.org/search
GEOCODING_CACHE_SECONDS=86400
GEOCODING_CONTACT_EMAIL=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CACHE_SECONDS=900
GEMINI_MAX_REQUESTS=6
GEMINI_WINDOW_MINUTES=60
GEMINI_LOCK_MINUTES=60
ENABLE_SWAGGER=true

# Mail / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Imperial Desk
SMTP_FROM_EMAIL=

SENTRY_DSN=
