generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ConsentKind {
  LEGAL
  COOKIE
}

enum AuditSeverity {
  INFO
  WARN
  ERROR
}

enum OrderStatus {
  COMPLETED
  CANCELLED
}

enum BuyerType {
  PERSON
  COMPANY
}

enum CurrencyCode {
  BRL
  USD
  EUR
}

enum OneTimeCodePurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model User {
  id                  String               @id @default(cuid())
  fullName            String
  companyName         String?
  email               String               @unique
  passwordHash        String
  status              UserStatus           @default(ACTIVE)
  preferredCurrency   CurrencyCode         @default(BRL)
  emailVerifiedAt     DateTime?
  passwordChangedAt   DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  oneTimeCodes        OneTimeCode[]
  consents            UserConsent[]
  cookiePreference    CookiePreference?
  auditLogs           AuditLog[]
  demoAccessGrants    DemoAccessGrant[]
  products            Product[]
  employees           Employee[]
  orders              Order[]
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  demoAccessGrant DemoAccessGrant?

  @@index([userId, expiresAt])
}

model DemoAccessGrant {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique
  dayKey     String
  ipHash     String
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  endedAt    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([ipHash, dayKey])
  @@index([userId, dayKey])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
}

model OneTimeCode {
  id         String             @id @default(cuid())
  userId     String
  email      String
  purpose    OneTimeCodePurpose
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime           @default(now())
  ipAddress  String?
  userAgent  String?
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
  @@index([email, purpose, expiresAt])
  @@index([expiresAt, usedAt])
}

model ConsentDocument {
  id          String        @id @default(cuid())
  key         String
  version     String
  title       String
  description String?
  contentUrl  String?
  kind        ConsentKind
  required    Boolean       @default(true)
  active      Boolean       @default(true)
  publishedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  consents    UserConsent[]

  @@unique([key, version])
  @@index([key, active])
}

model UserConsent {
  id          String          @id @default(cuid())
  userId      String
  documentId  String
  acceptedAt  DateTime        @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    ConsentDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
}

model CookiePreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  necessary  Boolean  @default(true)
  analytics  Boolean  @default(false)
  marketing  Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String        @id @default(cuid())
  actorUserId String?
  event       String
  resource    String
  resourceId  String?
  severity    AuditSeverity @default(INFO)
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime      @default(now())
  actor       User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([actorUserId, createdAt])
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  brand       String?
  category    String
  packagingClass String @default("Cadastro rapido")
  measurementUnit String @default("UN")
  measurementValue Decimal @default(1) @db.Decimal(10, 2)
  unitsPerPackage Int @default(1)
  description String?
  unitCost    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  currency    CurrencyCode @default(BRL)
  stock       Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([userId, active])
  @@unique([userId, name])
}

model Employee {
  id           String   @id @default(cuid())
  userId       String
  employeeCode String
  displayName  String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales        Order[]

  @@index([userId, active])
  @@unique([userId, employeeCode])
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  customerName String?
  buyerType    BuyerType?
  buyerDocument String?
  buyerDistrict String?
  buyerCity    String?
  buyerState   String?
  buyerCountry String?
  buyerLatitude Float?
  buyerLongitude Float?
  employeeId   String?
  sellerCode   String?
  sellerName   String?
  channel      String?
  notes        String?
  currency     CurrencyCode @default(BRL)
  status       OrderStatus @default(COMPLETED)
  totalRevenue Decimal     @db.Decimal(10, 2)
  totalCost    Decimal     @db.Decimal(10, 2)
  totalProfit  Decimal     @db.Decimal(10, 2)
  totalItems   Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  cancelledAt  DateTime?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([employeeId, createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  category    String
  quantity    Int
  currency    CurrencyCode @default(BRL)
  unitCost    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineRevenue Decimal  @db.Decimal(10, 2)
  lineCost    Decimal  @db.Decimal(10, 2)
  lineProfit  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId, createdAt])
}
