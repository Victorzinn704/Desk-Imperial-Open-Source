{
  "name": "@partner/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --tsconfig tsconfig.json src/main.ts",
    "build": "npm run prisma:generate && nest build --builder tsc",
    "build:verify": "npm run prisma:validate && nest build --builder tsc",
    "start": "node ./scripts/start-dist.mjs",
    "backfill:product-images:pexels": "node ./scripts/backfill-product-images-pexels.mjs",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "ts-node --project tsconfig.json --transpile-only prisma/seed.ts",
    "prisma:repair-demo": "ts-node --project tsconfig.json --transpile-only prisma/repair-demo.ts",
    "prisma:backfill:product-catalog-base": "ts-node --project tsconfig.json --transpile-only prisma/backfill-product-catalog-base.ts",
    "prisma:backfill:product-images:pexels": "ts-node --project tsconfig.json --transpile-only prisma/backfill-product-images-pexels.ts",
    "prisma:refresh:bi": "node ./scripts/refresh-bi.mjs",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "test": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs jest --runInBand",
    "test:vitest": "vitest run",
    "test:coverage:sonar": "cross-env SONAR_COVERAGE=true NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs jest --runInBand --coverage",
    "test:critical": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs jest --runInBand test/csrf.guard.spec.ts test/session.guard.spec.ts test/auth-rate-limit.service.spec.ts test/admin-pin.guard.spec.ts test/cache.service.spec.ts test/operations-realtime.socket-auth.spec.ts",
    "test:e2e": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs jest --config ./test/jest-e2e.json --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.17",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "6.19.3",
    "@sentry/nestjs": "^10.51.0",
    "@sentry/opentelemetry": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "escape-html": "^1.0.3",
    "grammy": "^1.42.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "nestjs-pino": "^4.4.1",
    "openapi3-ts": "^4.5.0",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "prisma": "6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.13.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.36.0",
    "jest": "^30.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "vitest": "^4.1.2",
    "vitest-tsconfig-paths": "^3.4.1"
  }
}
