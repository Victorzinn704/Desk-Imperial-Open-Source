{
  "name": "@partner/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "node ./scripts/start.mjs",
    "analyze": "next build --profile",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs vitest run",
    "test:coverage": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs vitest run --coverage",
    "test:coverage:sonar": "cross-env SONAR_COVERAGE=true NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs vitest run --coverage",
    "test:critical": "cross-env NODE_OPTIONS=--localstorage-file=./.cache/node-localstorage node ../../scripts/run-with-sanitized-node-options.mjs vitest run lib/validation.test.ts lib/api.test.ts lib/operations/operations-query.test.ts components/operations/comanda-patching.test.ts components/operations/cash-patching.test.ts components/operations/kitchen-patching.test.ts components/operations/mesa-patching.test.ts components/operations/edge-cases.test.ts components/operations/use-operations-realtime.socket.test.tsx components/staff-mobile/staff-mobile-shell.test.tsx components/staff-mobile/mobile-comanda-list.test.tsx components/owner-mobile/owner-mobile-shell.test.tsx components/owner-mobile/owner-comandas-view.test.tsx components/dashboard/hooks/useDashboardMutations.test.tsx --reporter=dot",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:critical": "playwright test e2e/critical-flows.spec.ts --project=chromium",
    "test:e2e:headed": "playwright test --project=chromium --headed"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.3.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-virtual": "^3.13.23",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.544.0",
    "nanoid": "^3.3.11",
    "next": "^16.1.7",
    "qz-tray": "^2.2.5",
    "react": "^19.1.1",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-arm64-gnu": "4.2.1",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.1.7",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "vitest": "^4.1.2",
    "vitest-tsconfig-paths": "^3.4.1"
  }
}
