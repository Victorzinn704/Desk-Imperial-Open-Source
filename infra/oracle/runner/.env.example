RUNNER_REPORTS_DIR=/opt/desk-imperial/infra/oracle/runner/reports
RUNNER_RESTORE_DIR=/opt/desk-imperial/infra/oracle/runner/restore

PGBACKREST_STANZA=deskimperial_pg17
PGBACKREST_REPO_PATH=/var/lib/pgbackrest
PGBACKREST_REPO_RETENTION_FULL=2
PGBACKREST_REPO_RETENTION_DIFF=7
PGBACKREST_CIPHER_TYPE=aes-256-cbc
PGBACKREST_CIPHER_PASS=<SECRET>
PGBACKREST_REPO_S3_BUCKET=<SECRET>
PGBACKREST_REPO_S3_ENDPOINT=https://<bucket-host>
PGBACKREST_REPO_S3_REGION=sa-saopaulo-1
PGBACKREST_REPO_S3_KEY=<SECRET>
PGBACKREST_REPO_S3_KEY_SECRET=<SECRET>

AMPERE_SSH_HOST=10.220.10.10
AMPERE_SSH_USER=ubuntu
AMPERE_SSH_KEY_PATH=/home/ubuntu/.ssh/desk_lohana_ampere_ed25519
AMPERE_DOCKER_CONTAINER=desk-db-postgres
AMPERE_LOG_GLOB=/var/log/postgresql/*.json
