# Oracle / vm-free-01 runtime base
# DADO AUSENTE: substitua os placeholders pelos valores reais da VM, do WireGuard e dos segredos.

NODE_ENV=production
APP_NAME="DESK IMPERIAL"

# Domínios públicos expostos pelo Nginx na Oracle VM.
APP_DOMAIN=app.deskimperial.online
API_DOMAIN=api.deskimperial.online
APP_URL=https://app.deskimperial.online
NEXT_PUBLIC_APP_URL=https://app.deskimperial.online
NEXT_PUBLIC_API_URL=https://api.deskimperial.online
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
CERTBOT_EMAIL=replace-with-your-email@example.com

# API / banco / cache.
PORT=4000
DATABASE_URL=postgresql://desk_app:<APP_DB_PASSWORD>@10.220.10.10:6432/deskimperial?schema=public&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://desk_migration:<MIGRATION_DB_PASSWORD>@10.220.10.10:5432/deskimperial?schema=public
REDIS_PASSWORD=<LONG_RANDOM_REDIS_PASSWORD>
TRUST_PROXY=true
COOKIE_SECRET=<LONG_RANDOM_COOKIE_SECRET>
CSRF_SECRET=<LONG_RANDOM_CSRF_SECRET>
ENCRYPTION_KEY=<32_CHAR_AES256_GCM_KEY>
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
SESSION_TTL_HOURS=24

# Opcional.
ENABLE_API_DOCS=false

# Sentry / runtime + build
SENTRY_DSN=
SENTRY_ENABLED=true
SENTRY_ENABLE_LOGS=false
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.02
SENTRY_PROFILE_LIFECYCLE=trace
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=true
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
NEXT_PUBLIC_SENTRY_ENABLE_LOGS=false
SENTRY_WEB_DSN=
SENTRY_WEB_ENABLED=true
SENTRY_WEB_TRACES_SAMPLE_RATE=0.1
SENTRY_WEB_ENVIRONMENT=production
SENTRY_WEB_RELEASE=
SENTRY_WEB_SEND_DEFAULT_PII=false
SENTRY_WEB_ENABLE_LOGS=false
SENTRY_ORG=desk-imperial
SENTRY_PROJECT_WEB=javascript-nextjs
SENTRY_AUTH_TOKEN=
