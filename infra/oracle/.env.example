# Oracle / VM runtime base
# DADO AUSENTE: substitua os placeholders pelos valores reais da sua VM, do Neon e dos segredos.

NODE_ENV=production
APP_NAME="DESK IMPERIAL"

# Domínios públicos expostos pelo Nginx na Oracle VM.
APP_DOMAIN=app.deskimperial.online
API_DOMAIN=api.deskimperial.online
APP_URL=https://app.deskimperial.online
NEXT_PUBLIC_APP_URL=https://app.deskimperial.online
NEXT_PUBLIC_API_URL=https://api.deskimperial.online
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
CERTBOT_EMAIL=replace-with-your-email@example.com

# API / banco / cache.
PORT=4000
DATABASE_URL=<NEON_DATABASE_URL>
DIRECT_URL=<NEON_DIRECT_URL>
REDIS_PASSWORD=<LONG_RANDOM_REDIS_PASSWORD>
TRUST_PROXY=true
COOKIE_SECRET=<LONG_RANDOM_COOKIE_SECRET>
CSRF_SECRET=<LONG_RANDOM_CSRF_SECRET>
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
SESSION_TTL_HOURS=24

# Opcional.
ENABLE_SWAGGER=false
SWAGGER_ALLOW_IN_PRODUCTION=false
