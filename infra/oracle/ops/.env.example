OPS_PRIVATE_IP=10.220.10.2

GRAFANA_ADMIN_USER=desk_observability_admin
GRAFANA_ADMIN_PASSWORD=<LONG_RANDOM_GRAFANA_PASSWORD>

METABASE_SITE_NAME=Desk Imperial BI
METABASE_ENCRYPTION_SECRET_KEY=<LONG_RANDOM_32_CHAR_METABASE_KEY>
METABASE_MB_DB_TYPE=h2
METABASE_MB_DB_FILE=/metabase-data/metabase.db
# Os valores abaixo servem como referência de data source do Metabase.
# Eles não são consumidos automaticamente pelo compose.
METABASE_DB_HOST=<DESK_DB_PRIVATE_IP>
METABASE_DB_PORT=5432
METABASE_DB_NAME=deskimperial
METABASE_DB_USER=desk_bi_reader
METABASE_DB_PASSWORD=<LONG_RANDOM_BI_PASSWORD>

ALERTMANAGER_ENV=development
ALERTMANAGER_WEBHOOK_URL=
LOKI_RETENTION_PERIOD=15d

PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=3GB

SONAR_JDBC_USERNAME=sonarqube
SONAR_JDBC_PASSWORD=<LONG_RANDOM_SONAR_PASSWORD>
SONAR_WEB_JAVAOPTS=-Xms256m -Xmx768m
SONAR_CE_JAVAOPTS=-Xms256m -Xmx768m
SONAR_SEARCH_JAVAOPTS=-Xms768m -Xmx768m -XX:MaxDirectMemorySize=256m
