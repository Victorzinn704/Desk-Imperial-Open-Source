{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["apps/web/*"],
      "@contracts/contracts": ["packages/types/src/index"]
    }
  },
  "include": [
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "packages/types/src/**/*.ts"
  ]
}
