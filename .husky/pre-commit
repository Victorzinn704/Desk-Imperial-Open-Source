set -e

# 1. Gitleaks — detecta segredos antes de qualquer outra coisa
npm run lint:secrets:staged

# 2. Biome lint rápido nos arquivos staged
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | head -50)
if [ -n "$STAGED_TS" ]; then
  npm exec -- biome lint --no-errors-on-unmatched $STAGED_TS
fi

# 3. Prettier + ESLint via lint-staged (comportamento existente)
npm run lint-staged
